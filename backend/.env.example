# ==========================================
# CONFIGURAÇÃO DO SUPABASE POSTGRESQL
# ==========================================
# 
# 📋 Como obter essas credenciais:
# 1. Acesse https://supabase.com e crie uma conta
# 2. Crie um novo projeto
# 3. Vá para "Project Settings" > "Database" na seção esquerda
# 4. Você encontrará a "Connection string" no formato:
#    postgresql://[user]:[password]@[host]:[port]/[database]
# 5. Extraia cada valor e preencha as variáveis abaixo
#
# ==========================================

# Nome do usuário do banco de dados (padrão: postgres)
DB_USER=postgres

# Host do servidor PostgreSQL no Supabase
# Exemplo: seu-projeto.supabase.co
DB_HOST=seu-projeto.supabase.co

# Porta do PostgreSQL (padrão: 5432)
DB_PORT=5432

# Nome do banco de dados (padrão: postgres)
DB_NAME=postgres

# Senha do usuário do banco de dados
# ⚠️  NUNCA compartilhe esta senha em repositórios públicos!
DB_PASSWORD=sua-senha-super-segura-aqui

# ==========================================
# CONFIGURAÇÃO DO SERVIDOR
# ==========================================

# Porta na qual o servidor Express rodará (padrão: 3000)
PORT=3000

# Ambiente (development, production, test)
NODE_ENV=development

# ==========================================
# NOTAS IMPORTANTES:
# ==========================================
# 
# 1. ⚠️  SEGURANÇA:
#    - Nunca commite o arquivo .env (ele já está no .gitignore)
#    - Use .env.example como template
#    - Em produção, use variáveis de ambiente do seu hosting
#
# 2. 🔐 CREDENCIAIS SUPABASE:
#    - Você pode regenerar a senha a qualquer momento
#    - Credenciais com escopo restrito são recomendadas
#    - Use service role key para operações do servidor
#
# 3. 📊 SUPABASE DASHBOARD:
#    - URL: https://supabase.com/dashboard
#    - Projeto Settings > Database > Connection String
#    - Copie a connection string e extraia os valores
#
# 4. 🧪 TESTES:
#    - Execute: npm run test:db
#    - Verifique se a conexão está funcionando
#
